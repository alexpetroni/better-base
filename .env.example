# Copy to .env and adjust. Values below are what a human on the host machine uses;
# if the app itself runs inside a container with docker-out-of-docker, replace
# `localhost` with `host.docker.internal`.

# Which site this deployment is: `sleep` | `life`. Selects the site config.
SITE_ID=sleep

# Postgres connection for the active site. One database per site:
#   sleep -> better_sleep, life -> better_life (both created by docker compose).
# For SITE_ID=life use: postgres://better:better@localhost:5433/better_life
DATABASE_URL=postgres://better:better@localhost:5433/better_sleep

# Dedicated database for integration tests; dropped and re-migrated per test run.
TEST_DATABASE_URL=postgres://better:better@localhost:5433/better_test

# Public origin of this deployment.
PUBLIC_SITE_URL=http://localhost:5173

# Host port that docker compose publishes Postgres on (container port is 5432).
DB_PORT=5433

# Secret for better-auth session signing/hashing. Generate a long random value
# for anything beyond local dev (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=dev-only-secret-change-me-0123456789

# --- Media storage (S3-compatible) ---------------------------------------
# Dev: MinIO from docker compose. Prod: Cloudflare R2 — same variables, no
# code changes (endpoint, creds and bucket all come from here).
# The endpoint must be reachable BOTH by the server (presign/confirm/delete)
# and by the browser (it PUTs directly to the presigned URL).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=better-media
S3_SECRET_KEY=better-media-secret
S3_BUCKET=better-base-media
S3_REGION=us-east-1

# Host ports docker compose publishes MinIO on (API / web console).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- imgproxy --------------------------------------------------------------
# Public base URL the app embeds in <img> tags (browser-reachable).
IMGPROXY_URL=http://localhost:8888
# Hex-encoded HMAC key/salt; MUST match the imgproxy container's env
# (docker-compose.yml defaults to these same dev values). Generate real ones
# for prod: `openssl rand -hex 32` twice.
IMGPROXY_KEY=bfd9adf6c395743b3c86b59c5ba7c418986de2ce4f2d6828812a8bf02ae838fb
IMGPROXY_SALT=04efffdcb59e1b8953506cfd05e0f30de80767ef4c5710ecf514f49a6352fec5
# Host port docker compose publishes imgproxy on (container port 8080).
IMGPROXY_PORT=8888

# --- Stripe (shop) ----------------------------------------------------------
# Leave STRIPE_SECRET_KEY empty to run on the deterministic in-memory MOCK
# gateway (dev default; all tests run on the mock). Set a TEST key
# (sk_test_…) for a real end-to-end manual check — never a live key in dev.
STRIPE_SECRET_KEY=
# Webhook signing secret: from the Stripe dashboard endpoint config, or the
# one `stripe listen` prints. Any non-empty value works for the mock/dev flow.
STRIPE_WEBHOOK_SECRET=whsec_dev_only_secret_change_me

# --- Email (Resend) --------------------------------------------------------
# Dry-run is the DEFAULT: emails are recorded in the email_log table instead
# of being sent. Real delivery requires EMAIL_DRYRUN=false AND a Resend key.
# Tests always run dry — never point a test environment at a real key.
EMAIL_DRYRUN=true
RESEND_API_KEY=
