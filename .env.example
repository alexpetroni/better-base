# Copy to .env and adjust. Values below are what a human on the host machine uses;
# if the app itself runs inside a container with docker-out-of-docker, replace
# `localhost` with `host.docker.internal`.

# Which site this deployment is: `sleep` | `life`. Selects the site config.
SITE_ID=sleep

# Postgres connection for the active site. One database per site:
#   sleep -> better_sleep, life -> better_life (both created by docker compose).
# For SITE_ID=life use: postgres://better:better@localhost:5433/better_life
DATABASE_URL=postgres://better:better@localhost:5433/better_sleep

# Dedicated database for integration tests; dropped and re-migrated per test run.
TEST_DATABASE_URL=postgres://better:better@localhost:5433/better_test

# Public origin of this deployment.
PUBLIC_SITE_URL=http://localhost:5173

# Host port that docker compose publishes Postgres on (container port is 5432).
DB_PORT=5433

# --- DB pool bounds & timeouts ----------------------------------------------
# All optional; the values below are the built-in defaults. They exist so a
# few hung requests can never hold connections forever and starve the app.
# Upper bound on open connections per process.
#DB_POOL_MAX=10
# How long a request waits for a free connection before failing (shed load).
#DB_POOL_CONNECTION_TIMEOUT_MS=5000
# Idle connections are closed after this.
#DB_POOL_IDLE_TIMEOUT_MS=30000
# Server-side statement_timeout: Postgres cancels any query running longer.
#DB_STATEMENT_TIMEOUT_MS=30000

# Secret for better-auth session signing/hashing. Generate a long random value
# for anything beyond local dev (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=dev-only-secret-change-me-0123456789

# Dedicated secret for app-signed tokens (newsletter confirm links, chat
# session cookies, upload-confirm tickets). MUST differ from
# BETTER_AUTH_SECRET — the app refuses to boot when they match, so one leaked
# secret never compromises both. Generate: `openssl rand -base64 32`.
# Rotating it invalidates outstanding confirm links and chat sessions.
TOKEN_SECRET=dev-only-token-secret-change-me-9876543210

# --- Media storage (S3-compatible) ---------------------------------------
# Dev: MinIO from docker compose. Prod: Cloudflare R2 — same variables, no
# code changes (endpoint, creds and bucket all come from here).
# The endpoint must be reachable BOTH by the server (presign/confirm/delete)
# and by the browser (it PUTs directly to the presigned URL).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=better-media
S3_SECRET_KEY=better-media-secret
S3_BUCKET=better-base-media
S3_REGION=us-east-1

# Host ports docker compose publishes MinIO on (API / web console).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- imgproxy --------------------------------------------------------------
# Public base URL the app embeds in <img> tags (browser-reachable).
IMGPROXY_URL=http://localhost:8888
# Hex-encoded HMAC key/salt that sign every imgproxy URL. NO committed
# defaults on purpose: generate your own pair, even for local dev —
#   openssl rand -hex 32   (run twice: once for the key, once for the salt)
# docker compose passes these same values to the imgproxy container and
# refuses to start while they are missing; the app refuses to boot too.
# Rotation: deploy new values to imgproxy and the app together (see
# DEPLOYMENT.md §6 — pages sign URLs per request, so a joint restart is safe).
IMGPROXY_KEY=
IMGPROXY_SALT=
# Host port docker compose publishes imgproxy on (container port 8080).
IMGPROXY_PORT=8888

# --- Stripe (shop) ----------------------------------------------------------
# Leave STRIPE_SECRET_KEY empty to run on the deterministic in-memory MOCK
# gateway (dev default; all tests run on the mock). Set a TEST key
# (sk_test_…) for a real end-to-end manual check — never a live key in dev.
STRIPE_SECRET_KEY=
# Webhook signing secret: from the Stripe dashboard endpoint config, or the
# one `stripe listen` prints. Any non-empty value works for the mock/dev flow.
STRIPE_WEBHOOK_SECRET=whsec_dev_only_secret_change_me
# Per-request cap on Stripe API calls (ms); default below. Retries are bounded
# in code (2, with idempotency keys), so a hung socket fails fast and handled.
#STRIPE_TIMEOUT_MS=20000

# --- Email (Resend) --------------------------------------------------------
# Dry-run is the DEFAULT: emails are recorded in the email_log table instead
# of being sent. Real delivery requires EMAIL_DRYRUN=false AND a Resend key.
# Tests always run dry — never point a test environment at a real key.
EMAIL_DRYRUN=true
RESEND_API_KEY=
# Per-call cap on the Resend API (ms); default below. A hung send becomes a
# retryable `error` row in email_log instead of pinning the request.
#RESEND_TIMEOUT_MS=10000

# --- Chat (assistant) --------------------------------------------------------
# `mock` (default) answers with deterministic canned ro replies — dev and ALL
# tests run on the mock. `anthropic` streams from the Anthropic API and then
# REQUIRES ANTHROPIC_API_KEY at boot (the server refuses to start without it).
# The key is never required in dev or tests.
CHAT_PROVIDER=mock
ANTHROPIC_API_KEY=
# Cap on time-to-response for one Anthropic call (ms); default below. Applies
# to reaching the API, not the duration of a healthy stream.
#ANTHROPIC_TIMEOUT_MS=60000
